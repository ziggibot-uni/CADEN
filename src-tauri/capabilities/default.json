{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for CADEN",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:event:default",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "store:default",
    "http:default",
    "opener:default",
    "dialog:default"
  ]
}
